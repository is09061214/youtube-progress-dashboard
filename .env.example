# Google スプレッドシートの ID（URL の /d/<ここ>/edit 部分）
# サンプルモードなら空でもOK。本番は必須。
SHEET_ID=

# サービスアカウントの JSON キーへのパス（ローカル実行時）
GOOGLE_APPLICATION_CREDENTIALS=./service_account.json

# 対象シートのタブ。WORKSHEET_NAME を設定するか、URL の gid= を WORKSHEET_GID に
WORKSHEET_NAME=
WORKSHEET_GID=

# サンプルデータで起動するモード（True にするとシートにアクセスせずダミーデータで動く）
USE_SAMPLE_DATA=True

# シート取得失敗時にサンプルへフォールバックするか（本番は False 推奨）
FALLBACK_TO_SAMPLE_ON_ERROR=False

# WORKSHEET_GID が一致するタブが無いとき、先頭シートにフォールバックするか（誤データ表示の事故防止のため既定 False）
FALLBACK_TO_FIRST_SHEET=False

# 自動更新の間隔（分）。0 にすると無効
REFRESH_INTERVAL_MINUTES=60

# 「今日」の判定に使うタイムゾーン
TIMEZONE=Asia/Tokyo

# サーバ待ち受けポート
PORT=8000
